#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
fi
# cmd-shim-target=/home/desenvolvedor23/projetos/DFR/ticket-hub/.pnpm-store/v11/links/@/pnpm/9.0.0/f9ad1512405e2d6d9268c6cb24c498bcd91688adc2ba2b2f92d8168e22de7c17/node_modules/pnpm/bin/pnpm.cjs
